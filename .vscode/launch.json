{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run GUI",
            "type": "debugpy",
            "request": "launch",
            "module": "subforge",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Debug Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Run Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests", "-v"],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
